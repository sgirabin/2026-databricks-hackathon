# Optional keys/configuration. The app runs with public data.gov.sg + OneMap search without most keys.
DATA_GOV_API_KEY=

# OneMap public search endpoint works without credentials for geocoding in this prototype.
# Add credentials later if you use newer authenticated endpoints or higher-volume API access.
ONEMAP_EMAIL=
ONEMAP_PASSWORD=
ONEMAP_ACCESS_TOKEN=

# Optional evidence search. Without this, the app shows source-backed manual search links only.
BING_SEARCH_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Optional Databricks AI / SQL hooks.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_MODEL_ENDPOINT=databricks-meta-llama-3-3-70b-instruct
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_SQL_ACCESS_TOKEN=
USE_DATABRICKS_SQL=false

# Optional Lakebase / Postgres search memory.
LAKEBASE_DATABASE_URL=

HOMEWISE_CATALOG=main
HOMEWISE_SCHEMA=homewise_sg
HOMEWISE_CACHE_DIR=data/cache
